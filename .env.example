# Set the key for whichever provider you use (pick one via `teamctx config provider`).
# Anthropic (default) — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
# OpenAI — https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# Gemini — https://aistudio.google.com/apikey
# GEMINI_API_KEY=...

# Required only if using teamctx pull (web contribution queue)
# Get these from Vercel dashboard → Storage → KV → .env.local
KV_REST_API_URL=https://...
KV_REST_API_TOKEN=...
